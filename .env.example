AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=

# 콤마로 여러 Origin을 허용할 수 있습니다.
# 예시: http://localhost:3000,https://my-frontend.example.com
CORS_ORIGINS=http://localhost:3000

# true/false로 오후 3시 게이트를 강제할 수 있습니다.
# 빈 값이면 현재 시간을 기준으로 판단합니다.
FORCE_AFTER_THREE_PM=

FLASK_DEBUG=true
