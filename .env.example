# Copilot SDK (Semantic Kernel) 설정
# Azure OpenAI 리소스 정보
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-10-21

# CORS 설정: 콤마로 여러 Origin을 허용할 수 있습니다.
# 예시: http://localhost:3000,https://my-frontend.example.com
CORS_ORIGINS=http://localhost:3000

# 시간 게이트: true/false로 오후 3시 게이트를 강제할 수 있습니다.
# 빈 값이면 현재 시간을 기준으로 판단합니다.
FORCE_AFTER_THREE_PM=

# 디버그 모드
FLASK_DEBUG=true
